{
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "core:window:allow-minimize",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-unminimize"
  ]
}
